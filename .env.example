# Buttondown newsletter embed (public; appears in built HTML)
# https://docs.buttondown.com/building-your-subscriber-base
PUBLIC_BUTTONDOWN_USERNAME=author-jessica-rocha

# Contact form proxy URL (public; Cloudflare Worker — see workers/contact-form/README.md)
# BREVO_API_KEY lives only on the Worker (wrangler secret), never here or in PUBLIC_* vars.
PUBLIC_CONTACT_FORM_ENDPOINT=https://jessicarocha-contact-form.your-subdomain.workers.dev

# Cloudflare Turnstile site key (public; contact page only)
# https://developers.cloudflare.com/turnstile/
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADSem5ZRCZHxVNib
