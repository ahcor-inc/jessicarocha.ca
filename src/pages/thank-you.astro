---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Thank You — Jessica Rocha"
  description="Thanks for reaching out."
>
  <Header />

  <section class="thankyou-section">
    <div class="container">
      <p class="section-label">Message Received</p>
      <h1 class="serif thankyou-heading">Thank You</h1>
      <span class="rule"></span>
      <p class="thankyou-text serif">
        Your message has been sent. Jessica reads every note personally
        and will do her best to get back to you soon.
      </p>
      <div class="thankyou-links">
        <a href="/" class="btn btn-dark">Back to Home</a>
        <a href="/books" class="btn btn-wine">Explore the Books</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
.thankyou-section {
  min-height: 80svh;
  display: flex;
  align-items: center;
  text-align: center;
  padding-block-start: 6rem;
}

.container { max-width: 600px; }

.thankyou-heading {
  font-size: clamp(3rem, 8vw, 5rem);
  font-weight: 300;
  margin-top: 0.5rem;
}

.thankyou-text {
  font-size: clamp(1.1rem, 2vw, 1.35rem);
  font-style: italic;
  font-weight: 300;
  color: var(--charcoal-mid);
  line-height: 1.65;
  margin-block: 1rem 2.5rem;
}

.thankyou-links {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
}
</style>
