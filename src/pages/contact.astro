---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { GOOGLE_PLAY_CURSED_BLOOD } from '../data/books';
---

<BaseLayout
  title="Contact — Jessica Rocha"
  description="Get in touch with author Jessica Rocha — for reader mail, media inquiries, or general questions."
>
  <Header />

  <section class="page-hero">
    <div class="container">
      <p class="section-label">Get in Touch</p>
      <h1 class="serif page-title">Contact</h1>
      <span class="rule"></span>
    </div>
  </section>

  <section class="section-gap">
    <div class="container contact-layout">
      <!-- ── FORM ── -->
      <div class="contact-form-wrap">
        <h2 class="serif contact-heading">Send a Message</h2>
        <p class="contact-intro">
          Reader mail, interview requests, book club questions, or just a note to say hello —
          all messages are welcome and read.
        </p>

        <form class="contact-form" id="contact-form">
          <div class="form-row form-row--two">
            <label class="form-field">
              <span class="field-label">Name</span>
              <input type="text" name="name" required placeholder="Your name" autocomplete="name" />
            </label>
            <label class="form-field">
              <span class="field-label">Email</span>
              <input type="email" name="email" required placeholder="your@email.com" autocomplete="email" />
            </label>
          </div>

          <label class="form-field">
            <span class="field-label">Subject</span>
            <select name="subject">
              <option value="">Select a reason for reaching out</option>
              <option value="reader-mail">Reader Mail</option>
              <option value="book-club">Book Club</option>
              <option value="media">Media / Interview</option>
              <option value="other">Other</option>
            </select>
          </label>

          <label class="form-field">
            <span class="field-label">Message</span>
            <textarea name="message" required rows="6" placeholder="Your message…"></textarea>
          </label>

          <button type="submit" class="btn btn-dark">Send Message</button>
        </form>
      </div>

      <!-- ── SIDEBAR ── -->
      <aside class="contact-sidebar">
        <div class="sidebar-block">
          <p class="section-label">Find Jessica Online</p>
          <ul class="social-list">
            <li>
              <a href="https://www.instagram.com/authorjessicarocha/" target="_blank" rel="noopener noreferrer">
                <span class="social-name">Instagram</span>
                <span class="social-handle">@authorjessicarocha</span>
              </a>
            </li>
            <li>
              <a href="https://www.tiktok.com/@author.jessicarocha" target="_blank" rel="noopener noreferrer">
                <span class="social-name">TikTok</span>
                <span class="social-handle">@author.jessicarocha</span>
              </a>
            </li>
            <li>
              <a href="https://www.facebook.com/AuthorJessicaRocha/" target="_blank" rel="noopener noreferrer">
                <span class="social-name">Facebook</span>
                <span class="social-handle">@AuthorJessicaRocha</span>
              </a>
            </li>
            <li>
              <a href="https://www.goodreads.com/author/show/21163939.Jessica_Rocha" target="_blank" rel="noopener noreferrer">
                <span class="social-name">Goodreads</span>
                <span class="social-handle">Jessica Rocha</span>
              </a>
            </li>
            <li>
              <a href="https://www.amazon.ca/stores/Jessica-Rocha/author/B08Q3XDPJF" target="_blank" rel="noopener noreferrer">
                <span class="social-name">Amazon</span>
                <span class="social-handle">Author Page</span>
              </a>
            </li>
            <li>
              <a href="https://www.inkitt.com/Jessica_Rocha" target="_blank" rel="noopener noreferrer">
                <span class="social-name">Inkitt</span>
                <span class="social-handle">@Jessica_Rocha</span>
              </a>
            </li>
            <li>
              <a href={GOOGLE_PLAY_CURSED_BLOOD} target="_blank" rel="noopener noreferrer">
                <span class="social-name">Google Play Books</span>
                <span class="social-handle">Jessica Rocha</span>
              </a>
            </li>
          </ul>
        </div>

        <div class="sidebar-block">
          <p class="section-label">Response Time</p>
          <p class="sidebar-text">
            Jessica reads all messages personally and does her best to respond within
            1–2 weeks. Reader mail is always a delight — please don't hesitate to reach out.
          </p>
        </div>

        <div class="sidebar-block">
          <p class="section-label">Media &amp; Press</p>
          <p class="sidebar-text">
            For interview requests, ARCs, or press inquiries, please select
            "Media / Interview" in the subject line above.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
.page-hero {
  background: var(--surface-raised);
  padding-block: clamp(6rem, 14vw, 10rem) 3rem;
  text-align: center;
  border-bottom: 1px solid var(--border);
}

.page-title {
  font-size: clamp(2.8rem, 8vw, 5.5rem);
  font-weight: 300;
  margin-top: 0.5rem;
}

.contact-layout {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 5rem;
  align-items: start;
}

.contact-heading {
  font-size: clamp(1.8rem, 3vw, 2.5rem);
  margin-bottom: 0.75rem;
}

.contact-intro {
  color: var(--charcoal-mid);
  font-size: 0.95rem;
  line-height: 1.8;
  margin-bottom: 2.5rem;
}

/* ── Form ── */
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.form-row--two {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.field-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--charcoal-mid);
}

.contact-form input,
.contact-form select,
.contact-form textarea {
  border: 1.5px solid var(--border);
  background: var(--surface);
  padding: 0.85em 1em;
  font-family: var(--font-sans);
  font-size: 0.95rem;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s;
  width: 100%;
}

.contact-form input:focus,
.contact-form select:focus,
.contact-form textarea:focus {
  border-color: var(--wine);
}

.contact-form textarea { resize: vertical; min-height: 140px; }

.contact-form .btn { align-self: flex-start; margin-top: 0.5rem; }

/* ── Sidebar ── */
.contact-sidebar {
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
  padding-top: 0.5rem;
}

.sidebar-block {
  padding-bottom: 2.5rem;
  border-bottom: 1px solid var(--border);
}

.sidebar-block:last-child { border-bottom: none; }

.social-list {
  list-style: none;
  margin-top: 1rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.social-list a {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  transition: color 0.2s;
}

.social-list a:hover .social-name { color: var(--wine-light); }

.social-name {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text);
  transition: color 0.2s;
}

.social-handle {
  font-size: 0.88rem;
  color: var(--charcoal-mid);
}

.sidebar-text {
  font-size: 0.9rem;
  line-height: 1.8;
  color: var(--charcoal-mid);
  margin-top: 0.75rem;
}

@media (max-width: 820px) {
  .contact-layout {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .form-row--two {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
const form = document.getElementById('contact-form');
form?.addEventListener('submit', (e) => {
  e.preventDefault();
  const fd = new FormData(form);
  const subject = fd.get('subject') || 'Contact';
  const body = `Name: ${fd.get('name')}\nEmail: ${fd.get('email')}\n\n${fd.get('message')}`;
  window.location.href = `mailto:hello@jessicarocha.ca?subject=${encodeURIComponent(String(subject))}&body=${encodeURIComponent(body)}`;
  setTimeout(() => {
    window.location.href = '/thank-you';
  }, 300);
});
</script>
