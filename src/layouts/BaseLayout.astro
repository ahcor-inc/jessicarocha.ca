---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  turnstileCsp?: boolean;
}

const {
  title = 'Jessica Rocha — Author',
  description = 'Official website of Jessica Rocha, Canadian author of supernatural romance.',
  image = '/og-default.jpg',
  turnstileCsp = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const turnstileCspContent = [
  "default-src 'self'",
  "script-src 'self' https://challenges.cloudflare.com",
  "frame-src https://challenges.cloudflare.com",
  "style-src 'self' 'unsafe-inline'",
  "img-src 'self' data: https:",
  "font-src 'self' data:",
  "connect-src 'self' https:",
].join('; ');
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <meta name="referrer" content="strict-origin-when-cross-origin" />
    {turnstileCsp && (
      <meta http-equiv="Content-Security-Policy" content={turnstileCspContent} />
    )}

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
